{
  "locale": "pt-BR",
  "tiers": {
    "LOCAL": {
      "upstream": "ollama",
      "model": "agent-qwen:latest",
      "costPer1MTokens": {
        "input": 0,
        "output": 0
      },
      "ollamaOptions": {
        "num_ctx": 16384,
        "think": false
      }
    },
    "LIGHT": {
      "upstream": "moonshot",
      "model": "kimi-k2.5",
      "costPer1MTokens": {
        "input": 0,
        "output": 0
      }
    },
    "MEDIUM": {
      "upstream": "anthropic",
      "model": "claude-sonnet-4-6",
      "costPer1MTokens": {
        "input": 3.0,
        "output": 15.0
      }
    },
    "HEAVY": {
      "upstream": "anthropic",
      "model": "claude-sonnet-4-6",
      "costPer1MTokens": {
        "input": 3.0,
        "output": 15.0
      }
    }
  },
  "upstreams": {
    "ollama": {
      "baseUrl": "http://127.0.0.1:11434",
      "protocol": "ollama",
      "timeout": 60000
    },
    "moonshot": {
      "baseUrl": "https://api.moonshot.ai/v1",
      "protocol": "openai-compatible",
      "timeout": 30000
    },
    "anthropic": {
      "baseUrl": "https://api.anthropic.com",
      "protocol": "anthropic",
      "timeout": 60000
    }
  },
  "proxy": {
    "port": 8402,
    "bind": "127.0.0.1"
  },
  "session": {
    "enabled": true,
    "ttlMinutes": 30,
    "note": "Tier só sobe dentro da mesma conversa. Reseta após TTL de inatividade."
  },
  "fallback": {
    "maxRetries": 2,
    "note": "Se upstream retorna 429 ou 5xx, tenta o próximo tier acima. LOCAL→LIGHT→MEDIUM→HEAVY."
  },
  "budget": {
    "enabled": true,
    "dailyLimitUsd": 1.0,
    "monthlyLimitUsd": 30.0,
    "onExhausted": "force_local"
  },
  "shadowMode": true,
  "sensitive": {
    "action": "force_local",
    "patterns": [
      "senha|password|passwd",
      "credencia[il]s?|credential",
      "token(?!ize|ization|izar|ização)",
      "api[_\\s-]?key|chave.*api|secret[_\\s-]?key",
      "secret|segredo",
      "private[_\\s-]?key|chave.*privada",
      "bearer\\s+[a-zA-Z0-9._~+\\/=-]+",
      "sk-[a-zA-Z0-9]{20,}",
      "ssh-(?:rsa|ed25519|ecdsa)\\s",
      "\\b(?:ghp|gho|ghu|ghs|ghr)_[a-zA-Z0-9]{36,}\\b",
      "-----BEGIN.*(?:PRIVATE|RSA|EC).*KEY-----"
    ]
  },
  "scoring": {
    "boundaries": {
      "localLight": 0.08,
      "lightMedium": 0.1,
      "mediumHeavy": 0.35
    },
    "overrides": {
      "reasoningKeywordThreshold": 2,
      "largeContextTokens": 50000
    },
    "costBias": {
      "enabled": true,
      "weight": 0.3
    },
    "weights": {
      "tokenCount": 0.08,
      "codePresence": 0.1,
      "reasoningMarkers": 0.15,
      "technicalTerms": 0.1,
      "creativeMarkers": 0.05,
      "simpleIndicators": -0.18,
      "multiStepPatterns": 0.1,
      "questionComplexity": 0.08,
      "imperativeVerbs": 0.05,
      "constraints": 0.05,
      "outputFormat": 0.03,
      "domainSpecificity": 0.07,
      "agenticTasks": 0.05,
      "relayIndicators": -0.1
    },
